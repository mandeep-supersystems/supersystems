# SUPERSYSTEMS Platform Environment Configuration
# Copy this to .env and update values

# Application
FLASK_ENV=development
SECRET_KEY=<your-secret-key>
JWT_SECRET_KEY=<your-jwt-secret>

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:Rewari%40123@localhost:5432/SUPERSYSTEM
TEST_DATABASE_URL=postgresql://postgres:Rewari@123@localhost:5432/SUPERSYSTEM_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Email
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=<email>
MAIL_PASSWORD=<password>

# AI
AI_PROVIDER=bedrock
AI_MODEL_ID=anthropic.claude-v2

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./uploads
